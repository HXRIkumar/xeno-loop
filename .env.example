# ---- Supabase Postgres (Prisma) ----
DATABASE_URL=""
DIRECT_URL=""
# ---- Supabase client (browser Realtime) ----
NEXT_PUBLIC_SUPABASE_URL=""
NEXT_PUBLIC_SUPABASE_ANON_KEY=""
# ---- LLM (provider-agnostic; pick one via LLM_PROVIDER) ----
# openai (live, paid, reliable tool grounding) | groq (free) | gemini (quota-limited) | anthropic (stub)
LLM_PROVIDER="openai"
# OpenAI — the live provider. Get a key at https://platform.openai.com/api-keys
OPENAI_API_KEY=""
OPENAI_MODEL="gpt-4.1-mini"
# Groq — still selectable (LLM_PROVIDER=groq); free but the 8B hallucinates / 70B rate-limits
GROQ_API_KEY=""
GROQ_MODEL="llama-3.3-70b-versatile"
# Gemini — still selectable (LLM_PROVIDER=gemini); currently quota-limited
GEMINI_API_KEY=""
GEMINI_MODEL=""
# ---- Service wiring (localhost for now) ----
CHANNEL_SERVICE_URL=""
CRM_RECEIPTS_URL=""
# ---- Live updates ("true" to use Supabase Realtime; otherwise 3s polling) ----
NEXT_PUBLIC_REALTIME_ENABLED=""
